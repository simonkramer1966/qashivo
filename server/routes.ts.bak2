        currentClientCount: metadata.currentClientCount,
        currentMonthInvoices: metadata.currentMonthInvoices,
        subscriptionStartDate: metadata.subscriptionStartDate,
        subscriptionEndDate: metadata.subscriptionEndDate,
      };

      res.json(response);
