# Qashivo Environment Variables
# Copy this file to .env and fill in the values.

# ── Auth (Clerk) ────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://...

# ── AI ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email — SendGrid ───────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=cc@qashivo.com
SENDGRID_FROM_NAME=Qashivo Credit Control
INBOUND_WEBHOOK_TOKEN=

# ── Email — Connected (Gmail OAuth) ────────────────────────────
# See docs/OAUTH_SETUP.md for setup instructions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email — Connected (Outlook OAuth) ──────────────────────────
# See docs/OAUTH_SETUP.md for setup instructions
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Accounting — Xero OAuth ────────────────────────────────────
# See docs/OAUTH_SETUP.md for setup instructions
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# ── SMS — Vonage ───────────────────────────────────────────────
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_FROM_NUMBER=

# ── Voice — Retell AI ──────────────────────────────────────────
RETELL_API_KEY=

# ── Billing — Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Site Configuration ─────────────────────────────────────────
SITE_BASE_URL=https://your-domain.up.railway.app
REPLY_TOKEN_SECRET=
